define COMPILE_OBJ_CC
	@tmp="`mktemp -p "$${TMPDIR:-/tmp}" cbm-obj.XXXXXX`"; \
	$(CC) $(1) -c -o "$$tmp" "$<" && mv -f "$$tmp" "$@" \
		|| (rm -f "$$tmp" "$@" && tmp="`mktemp -p "$${TMPDIR:-/tmp}" cbm-obj.XXXXXX`" && $(CC) $(1) -c -o "$$tmp" "$<" && mv -f "$$tmp" "$@")
endef

define COMPILE_OBJ_CXX
	@tmp="`mktemp -p "$${TMPDIR:-/tmp}" cbm-obj.XXXXXX`"; \
	$(CXX) $(1) -c -o "$$tmp" "$<" && mv -f "$$tmp" "$@" \
		|| (rm -f "$$tmp" "$@" && tmp="`mktemp -p "$${TMPDIR:-/tmp}" cbm-obj.XXXXXX`" && $(CXX) $(1) -c -o "$$tmp" "$<" && mv -f "$$tmp" "$@")
endef

