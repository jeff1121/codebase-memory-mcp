# 手動全組合 prerequisite；刻意不接入日常 CI，且不清理共用 build/c。
# 為避免在某些 toolchain 下 ASan 觸發的大量物件 build race，這個手動門檻明確將 SANITIZE 清空。
RUST_ALL_OPTIN_MAKE_FLAGS = -j1 -f Makefile.cbm
rust-all-optin-test:
	$(MAKE) $(RUST_ALL_OPTIN_MAKE_FLAGS) BUILD_DIR=$(RUST_ALL_OPTIN_WRAPPER_BUILD_DIR) SANITIZE= clean-c
	@mkdir -p $(RUST_ALL_OPTIN_WRAPPER_BUILD_DIR)
	$(MAKE) $(RUST_ALL_OPTIN_MAKE_FLAGS) BUILD_DIR=$(RUST_ALL_OPTIN_WRAPPER_BUILD_DIR) SANITIZE= $(RUST_ALL_OPTIN_WRAPPER_FLAGS) $(RUST_ALL_OPTIN_WRAPPER_BUILD_DIR)/test-rust-ffi
	cd $(CURDIR) && $(RUST_ALL_OPTIN_WRAPPER_BUILD_DIR)/test-rust-ffi
	$(MAKE) $(RUST_ALL_OPTIN_MAKE_FLAGS) BUILD_DIR=$(RUST_ALL_OPTIN_WRAPPER_BUILD_DIR) SANITIZE= $(RUST_ALL_OPTIN_WRAPPER_FLAGS) $(RUST_ALL_OPTIN_WRAPPER_BUILD_DIR)/test-runner
	cd $(CURDIR) && $(RUST_ALL_OPTIN_WRAPPER_BUILD_DIR)/test-runner
	$(MAKE) $(RUST_ALL_OPTIN_MAKE_FLAGS) BUILD_DIR=$(RUST_ALL_OPTIN_WRAPPER_BUILD_DIR) SANITIZE= clean-c
	$(MAKE) $(RUST_ALL_OPTIN_MAKE_FLAGS) BUILD_DIR=$(RUST_ALL_OPTIN_WRAPPER_BUILD_DIR) SANITIZE= $(RUST_ALL_OPTIN_WRAPPER_FLAGS) cbm
	cd $(CURDIR) && $(RUST_ALL_OPTIN_WRAPPER_BUILD_DIR)/codebase-memory-mcp --version
	$(MAKE) $(RUST_ALL_OPTIN_MAKE_FLAGS) BUILD_DIR=$(RUST_ALL_OPTIN_DIRECT_BUILD_DIR) SANITIZE= clean-c
	@mkdir -p $(RUST_ALL_OPTIN_DIRECT_BUILD_DIR)
	$(MAKE) $(RUST_ALL_OPTIN_MAKE_FLAGS) BUILD_DIR=$(RUST_ALL_OPTIN_DIRECT_BUILD_DIR) SANITIZE= $(RUST_ALL_OPTIN_DIRECT_FLAGS) $(RUST_ALL_OPTIN_DIRECT_BUILD_DIR)/test-rust-ffi
	cd $(CURDIR) && $(RUST_ALL_OPTIN_DIRECT_BUILD_DIR)/test-rust-ffi
	$(MAKE) $(RUST_ALL_OPTIN_MAKE_FLAGS) BUILD_DIR=$(RUST_ALL_OPTIN_DIRECT_BUILD_DIR) SANITIZE= $(RUST_ALL_OPTIN_DIRECT_FLAGS) $(RUST_ALL_OPTIN_DIRECT_BUILD_DIR)/test-runner
	cd $(CURDIR) && $(RUST_ALL_OPTIN_DIRECT_BUILD_DIR)/test-runner
	$(MAKE) $(RUST_ALL_OPTIN_MAKE_FLAGS) BUILD_DIR=$(RUST_ALL_OPTIN_DIRECT_BUILD_DIR) SANITIZE= $(RUST_ALL_OPTIN_DIRECT_FLAGS) cbm
	cd $(CURDIR) && $(RUST_ALL_OPTIN_DIRECT_BUILD_DIR)/codebase-memory-mcp --version

