RUST_ALL_OPTIN_DIRECT_FLAGS = $(filter-out CBM_USE_RUST_DUMP_VERIFY=1 CBM_USE_RUST_GIT_PATH_ABSOLUTE=1 CBM_USE_RUST_PIPELINE_SVELTEKIT_FILE_KIND=1 CBM_USE_RUST_PIPELINE_URL_PATH=1 CBM_USE_RUST_DISCOVER_TRAILING_SEP=1 CBM_USE_RUST_DISCOVER_PATH_JOIN=1 CBM_USE_RUST_DISCOVER_LOCAL_REL_PATH=1 CBM_USE_RUST_PIPELINE_JSON_PROP=1 CBM_USE_RUST_PIPELINE_GITHISTORY=1,$(RUST_ALL_OPTIN_COMMON_FLAGS)) \
	CBM_USE_RUST_TRACES_ONLY=1 \
	CBM_USE_RUST_PIPELINE_CONFIGURES_ONLY=1 \
	CBM_USE_RUST_STR_INTERN_ONLY=1 \
	CBM_USE_RUST_DUMP_VERIFY_ONLY=1 \
