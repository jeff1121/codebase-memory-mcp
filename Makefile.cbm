rust-discover-language-only-test:
	$(MAKE) -j1 -f Makefile.cbm BUILD_DIR=$(DISCOVER_LANGUAGE_DEFAULT_BUILD_DIR) SANITIZE= clean-c
	$(MAKE) -j1 -f Makefile.cbm BUILD_DIR=$(DISCOVER_LANGUAGE_DEFAULT_BUILD_DIR) SANITIZE= $(DISCOVER_LANGUAGE_DEFAULT_BUILD_DIR)/test-rust-ffi
	$(MAKE) -j1 -f Makefile.cbm BUILD_DIR=$(DISCOVER_LANGUAGE_DEFAULT_BUILD_DIR) SANITIZE= $(DISCOVER_LANGUAGE_DEFAULT_BUILD_DIR)/test-runner
	cd $(CURDIR) && $(DISCOVER_LANGUAGE_DEFAULT_BUILD_DIR)/test-runner
	$(MAKE) -j1 -f Makefile.cbm BUILD_DIR=$(DISCOVER_LANGUAGE_DIRECT_BUILD_DIR) SANITIZE= clean-c
	$(MAKE) -j1 -f Makefile.cbm BUILD_DIR=$(DISCOVER_LANGUAGE_DIRECT_BUILD_DIR) SANITIZE= CBM_USE_RUST_DISCOVER_LANGUAGE_ONLY=1 $(DISCOVER_LANGUAGE_DIRECT_BUILD_DIR)/test-rust-ffi
