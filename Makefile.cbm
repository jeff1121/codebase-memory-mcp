	CBM_USE_RUST_PIPELINE_TEST_DETECT=1 \
	CBM_USE_RUST_PIPELINE_CHECKED_EXCEPTION=1 \
	CBM_USE_RUST_PIPELINE_ARTIFACT_PATH=1 \
