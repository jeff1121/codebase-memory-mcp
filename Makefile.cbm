	cd $(CURDIR) && $(RUST_PIPELINE_REGISTRY_TEST_QN_DEFAULT_BUILD_DIR)/test-runner registry
	$(MAKE) -j1 -f Makefile.cbm BUILD_DIR=$(RUST_PIPELINE_REGISTRY_TEST_QN_DEFAULT_BUILD_DIR) SANITIZE= cbm
	cd $(CURDIR) && $(RUST_PIPELINE_REGISTRY_TEST_QN_DEFAULT_BUILD_DIR)/codebase-memory-mcp --version
	$(MAKE) -j1 -f Makefile.cbm BUILD_DIR=$(RUST_PIPELINE_REGISTRY_TEST_QN_DIRECT_BUILD_DIR) SANITIZE= CBM_USE_RUST_PIPELINE_REGISTRY_TEST_QN_ONLY=1 clean-c
	$(MAKE) -j1 -f Makefile.cbm BUILD_DIR=$(RUST_PIPELINE_REGISTRY_TEST_QN_DIRECT_BUILD_DIR) SANITIZE= CBM_USE_RUST_PIPELINE_REGISTRY_TEST_QN_ONLY=1 $(RUST_PIPELINE_REGISTRY_TEST_QN_DIRECT_BUILD_DIR)/test-rust-ffi
	cd $(CURDIR) && $(RUST_PIPELINE_REGISTRY_TEST_QN_DIRECT_BUILD_DIR)/test-rust-ffi
	$(MAKE) -j1 -f Makefile.cbm BUILD_DIR=$(RUST_PIPELINE_REGISTRY_TEST_QN_DIRECT_BUILD_DIR) SANITIZE= CBM_USE_RUST_PIPELINE_REGISTRY_TEST_QN_ONLY=1 $(RUST_PIPELINE_REGISTRY_TEST_QN_DIRECT_BUILD_DIR)/test-runner
	cd $(CURDIR) && $(RUST_PIPELINE_REGISTRY_TEST_QN_DIRECT_BUILD_DIR)/test-runner registry
	$(MAKE) -j1 -f Makefile.cbm BUILD_DIR=$(RUST_PIPELINE_REGISTRY_TEST_QN_DIRECT_BUILD_DIR) SANITIZE= CBM_USE_RUST_PIPELINE_REGISTRY_TEST_QN_ONLY=1 cbm
	cd $(CURDIR) && $(RUST_PIPELINE_REGISTRY_TEST_QN_DIRECT_BUILD_DIR)/codebase-memory-mcp --version
