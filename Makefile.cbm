rust-language-graph-parity:
	rm -rf $(RUST_PARITY_DIR)
	mkdir -p $(RUST_PARITY_DIR)
	$(MAKE) -f Makefile.cbm clean-c
	$(MAKE) -f Makefile.cbm cbm
	cp $(BUILD_DIR)/codebase-memory-mcp $(RUST_PARITY_DIR)/cbm-default
	$(MAKE) -f Makefile.cbm clean-c
	$(MAKE) -f Makefile.cbm CBM_USE_RUST_PIPELINE_REGISTRY=1 CBM_USE_RUST_PIPELINE_PLAN=1 CBM_USE_RUST_PIPELINE_ROUTE_CANON=1 CBM_USE_RUST_PIPELINE_K8S_FILE_CLASSIFIERS=1 CBM_USE_RUST_PIPELINE_TEST_DETECT=1 CBM_USE_RUST_PIPELINE_CHECKED_EXCEPTION=1 CBM_USE_RUST_PIPELINE_PROJECT_NAME=1 CBM_USE_RUST_PIPELINE_CONFIGURES=1 CBM_USE_RUST_STORE_FTS_TOKENIZER=1 cbm
	cp $(BUILD_DIR)/codebase-memory-mcp $(RUST_PARITY_DIR)/cbm-rust-pipeline
	cd $(CURDIR) && python3 scripts/rust-language-graph-parity.py $(RUST_PARITY_DIR)/cbm-default $(RUST_PARITY_DIR)/cbm-rust-pipeline

