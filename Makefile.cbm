PIPELINE_GITHISTORY_WRAPPER_BUILD_DIR = $(BUILD_DIR)/rust-pipeline-githistory-wrapper
PIPELINE_GITHISTORY_DIRECT_BUILD_DIR = $(BUILD_DIR)/rust-pipeline-githistory-direct
ifeq ($(strip $(RUST_FEATURES)),pipeline-githistory-only)
RUST_CARGO_TARGET_DIR = $(CARGO_TARGET_DIR)/cbm-pipeline-githistory-only
endif

.PHONY: rust-pipeline-githistory-optin-test rust-pipeline-githistory-only-test
rust-pipeline-githistory-optin-test:
	$(MAKE) -j1 -f Makefile.cbm BUILD_DIR=$(PIPELINE_GITHISTORY_DEFAULT_BUILD_DIR) SANITIZE= clean-c
	$(MAKE) -j1 -f Makefile.cbm BUILD_DIR=$(PIPELINE_GITHISTORY_DEFAULT_BUILD_DIR) SANITIZE= $(PIPELINE_GITHISTORY_DEFAULT_BUILD_DIR)/test-rust-ffi
	cd $(CURDIR) && $(PIPELINE_GITHISTORY_DEFAULT_BUILD_DIR)/test-rust-ffi
	$(MAKE) -j1 -f Makefile.cbm BUILD_DIR=$(PIPELINE_GITHISTORY_DEFAULT_BUILD_DIR) SANITIZE= $(PIPELINE_GITHISTORY_DEFAULT_BUILD_DIR)/test-runner
	cd $(CURDIR) && $(PIPELINE_GITHISTORY_DEFAULT_BUILD_DIR)/test-runner pipeline
	$(MAKE) -j1 -f Makefile.cbm BUILD_DIR=$(PIPELINE_GITHISTORY_WRAPPER_BUILD_DIR) SANITIZE= clean-c
	$(MAKE) -j1 -f Makefile.cbm BUILD_DIR=$(PIPELINE_GITHISTORY_WRAPPER_BUILD_DIR) SANITIZE= CBM_USE_RUST_PIPELINE_GITHISTORY=1 $(PIPELINE_GITHISTORY_WRAPPER_BUILD_DIR)/test-rust-ffi
	cd $(CURDIR) && $(PIPELINE_GITHISTORY_WRAPPER_BUILD_DIR)/test-rust-ffi
	$(MAKE) -j1 -f Makefile.cbm BUILD_DIR=$(PIPELINE_GITHISTORY_WRAPPER_BUILD_DIR) SANITIZE= CBM_USE_RUST_PIPELINE_GITHISTORY=1 $(PIPELINE_GITHISTORY_WRAPPER_BUILD_DIR)/test-runner
	cd $(CURDIR) && $(PIPELINE_GITHISTORY_WRAPPER_BUILD_DIR)/test-runner pipeline
	$(MAKE) -j1 -f Makefile.cbm BUILD_DIR=$(PIPELINE_GITHISTORY_WRAPPER_BUILD_DIR) SANITIZE= CBM_USE_RUST_PIPELINE_GITHISTORY=1 cbm
	cd $(CURDIR) && $(PIPELINE_GITHISTORY_WRAPPER_BUILD_DIR)/codebase-memory-mcp --version

rust-pipeline-githistory-only-test:
	$(MAKE) -j1 -f Makefile.cbm BUILD_DIR=$(PIPELINE_GITHISTORY_DEFAULT_BUILD_DIR) SANITIZE= clean-c
	$(MAKE) -j1 -f Makefile.cbm BUILD_DIR=$(PIPELINE_GITHISTORY_DEFAULT_BUILD_DIR) SANITIZE= $(PIPELINE_GITHISTORY_DEFAULT_BUILD_DIR)/test-rust-ffi
	cd $(CURDIR) && $(PIPELINE_GITHISTORY_DEFAULT_BUILD_DIR)/test-rust-ffi
	$(MAKE) -j1 -f Makefile.cbm BUILD_DIR=$(PIPELINE_GITHISTORY_DEFAULT_BUILD_DIR) SANITIZE= $(PIPELINE_GITHISTORY_DEFAULT_BUILD_DIR)/test-runner
	cd $(CURDIR) && $(PIPELINE_GITHISTORY_DEFAULT_BUILD_DIR)/test-runner pipeline
	$(MAKE) -j1 -f Makefile.cbm BUILD_DIR=$(PIPELINE_GITHISTORY_DIRECT_BUILD_DIR) SANITIZE= clean-c
	$(MAKE) -j1 -f Makefile.cbm BUILD_DIR=$(PIPELINE_GITHISTORY_DIRECT_BUILD_DIR) SANITIZE= CBM_USE_RUST_PIPELINE_GITHISTORY_ONLY=1 $(PIPELINE_GITHISTORY_DIRECT_BUILD_DIR)/test-rust-ffi
	cd $(CURDIR) && $(PIPELINE_GITHISTORY_DIRECT_BUILD_DIR)/test-rust-ffi
	$(MAKE) -j1 -f Makefile.cbm BUILD_DIR=$(PIPELINE_GITHISTORY_DIRECT_BUILD_DIR) SANITIZE= CBM_USE_RUST_PIPELINE_GITHISTORY_ONLY=1 $(PIPELINE_GITHISTORY_DIRECT_BUILD_DIR)/test-runner
	cd $(CURDIR) && $(PIPELINE_GITHISTORY_DIRECT_BUILD_DIR)/test-runner pipeline
	$(MAKE) -j1 -f Makefile.cbm BUILD_DIR=$(PIPELINE_GITHISTORY_DIRECT_BUILD_DIR) SANITIZE= CBM_USE_RUST_PIPELINE_GITHISTORY_ONLY=1 cbm
	cd $(CURDIR) && $(PIPELINE_GITHISTORY_DIRECT_BUILD_DIR)/codebase-memory-mcp --version
	@$(MAKE) -pn -f Makefile.cbm CBM_USE_RUST_PIPELINE_GITHISTORY_ONLY=1 | rg '^PIPELINE_TRACKABLE_FILE_SRCS = $$'
	@! $(MAKE) -Bn -f Makefile.cbm BUILD_DIR=$(PIPELINE_GITHISTORY_DIRECT_BUILD_DIR) SANITIZE= CBM_USE_RUST_PIPELINE_GITHISTORY_ONLY=1 cbm | rg -F 'src/pipeline/trackable_file.c'

