	@! $(MAKE) -Bn -f Makefile.cbm BUILD_DIR=$(RUST_PIPELINE_REGISTRY_TEST_QN_DIRECT_BUILD_DIR) SANITIZE= CBM_USE_RUST_PIPELINE_REGISTRY_TEST_QN_ONLY=1 cbm | rg -F 'src/pipeline/registry_test_qn.c'

