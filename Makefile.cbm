.PHONY: rust-pipeline-artifact-path-optin-test rust-pipeline-artifact-path-only-test
rust-pipeline-artifact-path-only-test:
	$(MAKE) -j1 -f Makefile.cbm BUILD_DIR=$(RUST_PIPELINE_ARTIFACT_PATH_DEFAULT_BUILD_DIR) clean-c
	$(MAKE) -j1 -f Makefile.cbm BUILD_DIR=$(RUST_PIPELINE_ARTIFACT_PATH_DEFAULT_BUILD_DIR) $(RUST_PIPELINE_ARTIFACT_PATH_DEFAULT_BUILD_DIR)/test-rust-ffi
	cd $(CURDIR) && $(RUST_PIPELINE_ARTIFACT_PATH_DEFAULT_BUILD_DIR)/test-rust-ffi
	$(MAKE) -j1 -f Makefile.cbm BUILD_DIR=$(RUST_PIPELINE_ARTIFACT_PATH_DEFAULT_BUILD_DIR) $(RUST_PIPELINE_ARTIFACT_PATH_DEFAULT_BUILD_DIR)/test-runner
	cd $(CURDIR) && $(RUST_PIPELINE_ARTIFACT_PATH_DEFAULT_BUILD_DIR)/test-runner artifact
	$(MAKE) -j1 -f Makefile.cbm BUILD_DIR=$(RUST_PIPELINE_ARTIFACT_PATH_DEFAULT_BUILD_DIR) cbm
	cd $(CURDIR) && $(RUST_PIPELINE_ARTIFACT_PATH_DEFAULT_BUILD_DIR)/codebase-memory-mcp --version
	$(MAKE) -j1 -f Makefile.cbm BUILD_DIR=$(RUST_PIPELINE_ARTIFACT_PATH_ONLY_BUILD_DIR) CBM_USE_RUST_PIPELINE_ARTIFACT_PATH_ONLY=1 clean-c
	$(MAKE) -j1 -f Makefile.cbm BUILD_DIR=$(RUST_PIPELINE_ARTIFACT_PATH_ONLY_BUILD_DIR) CBM_USE_RUST_PIPELINE_ARTIFACT_PATH_ONLY=1 $(RUST_PIPELINE_ARTIFACT_PATH_ONLY_BUILD_DIR)/test-rust-ffi
	cd $(CURDIR) && $(RUST_PIPELINE_ARTIFACT_PATH_ONLY_BUILD_DIR)/test-rust-ffi
	$(MAKE) -j1 -f Makefile.cbm BUILD_DIR=$(RUST_PIPELINE_ARTIFACT_PATH_ONLY_BUILD_DIR) CBM_USE_RUST_PIPELINE_ARTIFACT_PATH_ONLY=1 $(RUST_PIPELINE_ARTIFACT_PATH_ONLY_BUILD_DIR)/test-runner
	cd $(CURDIR) && $(RUST_PIPELINE_ARTIFACT_PATH_ONLY_BUILD_DIR)/test-runner artifact
	$(MAKE) -j1 -f Makefile.cbm BUILD_DIR=$(RUST_PIPELINE_ARTIFACT_PATH_ONLY_BUILD_DIR) CBM_USE_RUST_PIPELINE_ARTIFACT_PATH_ONLY=1 cbm
	cd $(CURDIR) && $(RUST_PIPELINE_ARTIFACT_PATH_ONLY_BUILD_DIR)/codebase-memory-mcp --version
	@$(MAKE) -j1 -pn -f Makefile.cbm \
		CBM_USE_RUST_PIPELINE_ARTIFACT_PATH_ONLY=1 | \
		rg '^ARTIFACT_PATH_SRCS = $$'
	@plan_file="$(RUST_PIPELINE_ARTIFACT_PATH_ONLY_BUILD_DIR)/artifact-path-source-negative.plan"; \
	$(MAKE) -j1 -Bn -f Makefile.cbm BUILD_DIR=$(RUST_PIPELINE_ARTIFACT_PATH_ONLY_BUILD_DIR) CBM_USE_RUST_PIPELINE_ARTIFACT_PATH_ONLY=1 cbm > "$$plan_file"; \
	if grep -Fq 'src/pipeline/artifact_path.c' "$$plan_file"; then \
		echo "direct artifact-path build still references src/pipeline/artifact_path.c"; \
		rm -f "$$plan_file"; \
		exit 1; \
	fi; \
	rm -f "$$plan_file"

