RUST_ALL_OPTIN_DIRECT_FLAGS += CBM_USE_RUST_STORE_PACKAGE_LIST_ONLY=1
RUST_ALL_OPTIN_DIRECT_FLAGS += CBM_USE_RUST_STORE_SAFE_PROPS_ONLY=1

# 階段性 C/Rust migration 使用的 Rust staticlib inputs。預設關閉：
# production C build 只有在 CBM_USE_RUST_* flag 啟用時才連 Rust。
CARGO ?= cargo
CARGO_TARGET_DIR ?= target
RUST_AUDIT_REQUIRED ?= 0
RUST_TARGET ?=
RUST_TARGET_FLAG = $(if $(RUST_TARGET),--target $(RUST_TARGET),)
RUST_TARGET_SUBDIR = $(if $(RUST_TARGET),$(RUST_TARGET)/,)
RUST_STATICLIB_NAME ?= libcbm_core.a
# C 連結使用專屬 Cargo target dir，避免手動 `cargo test --all-features` 與不同
# opt-in feature 的 staticlib 快取混用。每一組 Rust-only feature 使用獨立目錄。
RUST_CARGO_TARGET_DIR = $(CARGO_TARGET_DIR)/cbm-default
RUST_FEATURES =
ifeq ($(CBM_USE_RUST_TRACES_ONLY),1)
RUST_FEATURES += traces-only
endif
ifeq ($(CBM_USE_RUST_PIPELINE_CONFIGURES_ONLY),1)
