# Configlink helpers true-source gate
CONFIGLINK_HELPERS_DEFAULT_BUILD_DIR = $(BUILD_DIR)/rust-pipeline-configlink-helpers-default
CONFIGLINK_HELPERS_WRAPPER_BUILD_DIR = $(BUILD_DIR)/rust-pipeline-configlink-helpers-wrapper
CONFIGLINK_HELPERS_DIRECT_BUILD_DIR = $(BUILD_DIR)/rust-pipeline-configlink-helpers-direct
ifeq ($(strip $(RUST_FEATURES)),pipeline-configlink-helpers-only)
RUST_CARGO_TARGET_DIR = $(CARGO_TARGET_DIR)/cbm-pipeline-configlink-helpers-only
endif

.PHONY: rust-pipeline-configlink-helpers-optin-test rust-pipeline-configlink-helpers-only-test
rust-pipeline-configlink-helpers-optin-test:
	$(MAKE) -j1 -f Makefile.cbm BUILD_DIR=$(CONFIGLINK_HELPERS_DEFAULT_BUILD_DIR) SANITIZE= clean-c
	$(MAKE) -j1 -f Makefile.cbm BUILD_DIR=$(CONFIGLINK_HELPERS_DEFAULT_BUILD_DIR) SANITIZE= $(CONFIGLINK_HELPERS_DEFAULT_BUILD_DIR)/test-rust-ffi
	cd $(CURDIR) && $(CONFIGLINK_HELPERS_DEFAULT_BUILD_DIR)/test-rust-ffi
	$(MAKE) -j1 -f Makefile.cbm BUILD_DIR=$(CONFIGLINK_HELPERS_DEFAULT_BUILD_DIR) SANITIZE= $(CONFIGLINK_HELPERS_DEFAULT_BUILD_DIR)/test-runner
	cd $(CURDIR) && $(CONFIGLINK_HELPERS_DEFAULT_BUILD_DIR)/test-runner pipeline
	$(MAKE) -j1 -f Makefile.cbm BUILD_DIR=$(CONFIGLINK_HELPERS_WRAPPER_BUILD_DIR) SANITIZE= clean-c
	$(MAKE) -j1 -f Makefile.cbm BUILD_DIR=$(CONFIGLINK_HELPERS_WRAPPER_BUILD_DIR) SANITIZE= CBM_USE_RUST_PIPELINE_CONFIGLINK_HELPERS=1 $(CONFIGLINK_HELPERS_WRAPPER_BUILD_DIR)/test-rust-ffi
	cd $(CURDIR) && $(CONFIGLINK_HELPERS_WRAPPER_BUILD_DIR)/test-rust-ffi
	$(MAKE) -j1 -f Makefile.cbm BUILD_DIR=$(CONFIGLINK_HELPERS_WRAPPER_BUILD_DIR) SANITIZE= CBM_USE_RUST_PIPELINE_CONFIGLINK_HELPERS=1 $(CONFIGLINK_HELPERS_WRAPPER_BUILD_DIR)/test-runner
	cd $(CURDIR) && $(CONFIGLINK_HELPERS_WRAPPER_BUILD_DIR)/test-runner pipeline
	$(MAKE) -j1 -f Makefile.cbm BUILD_DIR=$(CONFIGLINK_HELPERS_WRAPPER_BUILD_DIR) SANITIZE= CBM_USE_RUST_PIPELINE_CONFIGLINK_HELPERS=1 cbm
	cd $(CURDIR) && $(CONFIGLINK_HELPERS_WRAPPER_BUILD_DIR)/codebase-memory-mcp --version

rust-pipeline-configlink-helpers-only-test:
	$(MAKE) -j1 -f Makefile.cbm BUILD_DIR=$(CONFIGLINK_HELPERS_DEFAULT_BUILD_DIR) SANITIZE= clean-c
	$(MAKE) -j1 -f Makefile.cbm BUILD_DIR=$(CONFIGLINK_HELPERS_DEFAULT_BUILD_DIR) SANITIZE= $(CONFIGLINK_HELPERS_DEFAULT_BUILD_DIR)/test-rust-ffi
	cd $(CURDIR) && $(CONFIGLINK_HELPERS_DEFAULT_BUILD_DIR)/test-rust-ffi
	$(MAKE) -j1 -f Makefile.cbm BUILD_DIR=$(CONFIGLINK_HELPERS_DEFAULT_BUILD_DIR) SANITIZE= $(CONFIGLINK_HELPERS_DEFAULT_BUILD_DIR)/test-runner
	cd $(CURDIR) && $(CONFIGLINK_HELPERS_DEFAULT_BUILD_DIR)/test-runner pipeline
	$(MAKE) -j1 -f Makefile.cbm BUILD_DIR=$(CONFIGLINK_HELPERS_DIRECT_BUILD_DIR) SANITIZE= clean-c
	$(MAKE) -j1 -f Makefile.cbm BUILD_DIR=$(CONFIGLINK_HELPERS_DIRECT_BUILD_DIR) SANITIZE= CBM_USE_RUST_PIPELINE_CONFIGLINK_HELPERS_ONLY=1 $(CONFIGLINK_HELPERS_DIRECT_BUILD_DIR)/test-rust-ffi
	cd $(CURDIR) && $(CONFIGLINK_HELPERS_DIRECT_BUILD_DIR)/test-rust-ffi
	$(MAKE) -j1 -f Makefile.cbm BUILD_DIR=$(CONFIGLINK_HELPERS_DIRECT_BUILD_DIR) SANITIZE= CBM_USE_RUST_PIPELINE_CONFIGLINK_HELPERS_ONLY=1 $(CONFIGLINK_HELPERS_DIRECT_BUILD_DIR)/test-runner
	cd $(CURDIR) && $(CONFIGLINK_HELPERS_DIRECT_BUILD_DIR)/test-runner pipeline
	$(MAKE) -j1 -f Makefile.cbm BUILD_DIR=$(CONFIGLINK_HELPERS_DIRECT_BUILD_DIR) SANITIZE= CBM_USE_RUST_PIPELINE_CONFIGLINK_HELPERS_ONLY=1 cbm
	cd $(CURDIR) && $(CONFIGLINK_HELPERS_DIRECT_BUILD_DIR)/codebase-memory-mcp --version
	@$(MAKE) -pn -f Makefile.cbm CBM_USE_RUST_PIPELINE_CONFIGLINK_HELPERS_ONLY=1 | rg '^CONFIGLINK_HELPERS_SRCS = $$'
	@! $(MAKE) -Bn -f Makefile.cbm BUILD_DIR=$(CONFIGLINK_HELPERS_DIRECT_BUILD_DIR) SANITIZE= CBM_USE_RUST_PIPELINE_CONFIGLINK_HELPERS_ONLY=1 cbm | rg -F 'src/pipeline/configlink_helpers.c'

rust-ci: rust-pipeline-configlink-helpers-optin-test
rust-ci-tests: rust-pipeline-configlink-helpers-optin-test
rust-ci: rust-pipeline-configlink-helpers-only-test
rust-ci-tests: rust-pipeline-configlink-helpers-only-test

