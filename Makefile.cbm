RUST_PIPELINE_FQN_DEFAULT_BUILD_DIR = $(BUILD_DIR)/rust-pipeline-fqn-default
RUST_PIPELINE_FQN_OPTIN_BUILD_DIR = $(BUILD_DIR)/rust-pipeline-fqn-optin
RUST_PIPELINE_FQN_ONLY_BUILD_DIR = $(BUILD_DIR)/rust-pipeline-fqn-only

.PHONY: rust-pipeline-fqn-optin-test rust-pipeline-fqn-only-test
rust-pipeline-fqn-only-test:
	$(MAKE) -j1 -f Makefile.cbm BUILD_DIR=$(RUST_PIPELINE_FQN_DEFAULT_BUILD_DIR) SANITIZE= clean-c
	$(MAKE) -j1 -f Makefile.cbm BUILD_DIR=$(RUST_PIPELINE_FQN_DEFAULT_BUILD_DIR) SANITIZE= $(RUST_PIPELINE_FQN_DEFAULT_BUILD_DIR)/test-rust-ffi
	cd $(CURDIR) && $(RUST_PIPELINE_FQN_DEFAULT_BUILD_DIR)/test-rust-ffi
	$(MAKE) -j1 -f Makefile.cbm BUILD_DIR=$(RUST_PIPELINE_FQN_DEFAULT_BUILD_DIR) SANITIZE= $(RUST_PIPELINE_FQN_DEFAULT_BUILD_DIR)/test-runner
	cd $(CURDIR) && $(RUST_PIPELINE_FQN_DEFAULT_BUILD_DIR)/test-runner fqn
	$(MAKE) -j1 -f Makefile.cbm BUILD_DIR=$(RUST_PIPELINE_FQN_DEFAULT_BUILD_DIR) SANITIZE= cbm
	cd $(CURDIR) && $(RUST_PIPELINE_FQN_DEFAULT_BUILD_DIR)/codebase-memory-mcp --version
	$(MAKE) -j1 -f Makefile.cbm BUILD_DIR=$(RUST_PIPELINE_FQN_ONLY_BUILD_DIR) SANITIZE= CBM_USE_RUST_PIPELINE_FQN_ONLY=1 clean-c
	$(MAKE) -j1 -f Makefile.cbm BUILD_DIR=$(RUST_PIPELINE_FQN_ONLY_BUILD_DIR) SANITIZE= CBM_USE_RUST_PIPELINE_FQN_ONLY=1 $(RUST_PIPELINE_FQN_ONLY_BUILD_DIR)/test-rust-ffi
	cd $(CURDIR) && $(RUST_PIPELINE_FQN_ONLY_BUILD_DIR)/test-rust-ffi
	$(MAKE) -j1 -f Makefile.cbm BUILD_DIR=$(RUST_PIPELINE_FQN_ONLY_BUILD_DIR) SANITIZE= CBM_USE_RUST_PIPELINE_FQN_ONLY=1 $(RUST_PIPELINE_FQN_ONLY_BUILD_DIR)/test-runner
	cd $(CURDIR) && $(RUST_PIPELINE_FQN_ONLY_BUILD_DIR)/test-runner fqn
	$(MAKE) -j1 -f Makefile.cbm BUILD_DIR=$(RUST_PIPELINE_FQN_ONLY_BUILD_DIR) SANITIZE= CBM_USE_RUST_PIPELINE_FQN_ONLY=1 cbm
	cd $(CURDIR) && $(RUST_PIPELINE_FQN_ONLY_BUILD_DIR)/codebase-memory-mcp --version
	@$(MAKE) -pn -f Makefile.cbm CBM_USE_RUST_PIPELINE_FQN_ONLY=1 | rg '^FQN_SRCS = $$'
	@! $(MAKE) -Bn -f Makefile.cbm BUILD_DIR=$(RUST_PIPELINE_FQN_ONLY_BUILD_DIR) SANITIZE= CBM_USE_RUST_PIPELINE_FQN_ONLY=1 cbm | rg -F 'src/pipeline/fqn.c'

