	$(MAKE) -j1 -f Makefile.cbm BUILD_DIR=$(MCP_METHOD_KIND_WRAPPER_BUILD_DIR) SANITIZE= CBM_USE_RUST_MCP_METHOD_KIND=1 cbm
	cd $(CURDIR) && $(MCP_METHOD_KIND_WRAPPER_BUILD_DIR)/codebase-memory-mcp --version

rust-mcp-method-kind-only-test:
	$(MAKE) -j1 -f Makefile.cbm BUILD_DIR=$(MCP_METHOD_KIND_DEFAULT_BUILD_DIR) SANITIZE= clean-c
	$(MAKE) -j1 -f Makefile.cbm BUILD_DIR=$(MCP_METHOD_KIND_DEFAULT_BUILD_DIR) SANITIZE= $(MCP_METHOD_KIND_DEFAULT_BUILD_DIR)/test-rust-ffi
	cd $(CURDIR) && $(MCP_METHOD_KIND_DEFAULT_BUILD_DIR)/test-rust-ffi
	$(MAKE) -j1 -f Makefile.cbm BUILD_DIR=$(MCP_METHOD_KIND_DEFAULT_BUILD_DIR) SANITIZE= $(MCP_METHOD_KIND_DEFAULT_BUILD_DIR)/test-runner
	cd $(CURDIR) && $(MCP_METHOD_KIND_DEFAULT_BUILD_DIR)/test-runner mcp
	$(MAKE) -j1 -f Makefile.cbm BUILD_DIR=$(MCP_METHOD_KIND_DIRECT_BUILD_DIR) SANITIZE= clean-c
	$(MAKE) -j1 -f Makefile.cbm BUILD_DIR=$(MCP_METHOD_KIND_DIRECT_BUILD_DIR) SANITIZE= CBM_USE_RUST_MCP_METHOD_KIND_ONLY=1 $(MCP_METHOD_KIND_DIRECT_BUILD_DIR)/test-rust-ffi
	cd $(CURDIR) && $(MCP_METHOD_KIND_DIRECT_BUILD_DIR)/test-rust-ffi
	$(MAKE) -j1 -f Makefile.cbm BUILD_DIR=$(MCP_METHOD_KIND_DIRECT_BUILD_DIR) SANITIZE= CBM_USE_RUST_MCP_METHOD_KIND_ONLY=1 $(MCP_METHOD_KIND_DIRECT_BUILD_DIR)/test-runner
	cd $(CURDIR) && $(MCP_METHOD_KIND_DIRECT_BUILD_DIR)/test-runner mcp
	$(MAKE) -j1 -f Makefile.cbm BUILD_DIR=$(MCP_METHOD_KIND_DIRECT_BUILD_DIR) SANITIZE= CBM_USE_RUST_MCP_METHOD_KIND_ONLY=1 cbm
	cd $(CURDIR) && $(MCP_METHOD_KIND_DIRECT_BUILD_DIR)/codebase-memory-mcp --version
	@$(MAKE) -pn -f Makefile.cbm CBM_USE_RUST_MCP_METHOD_KIND_ONLY=1 | rg '^MCP_METHOD_KIND_SRCS = $$'
	@! $(MAKE) -Bn -f Makefile.cbm BUILD_DIR=$(MCP_METHOD_KIND_DIRECT_BUILD_DIR) SANITIZE= CBM_USE_RUST_MCP_METHOD_KIND_ONLY=1 cbm | rg -F 'src/mcp/method_kind.c'
	@$(MAKE) -Bn -f Makefile.cbm BUILD_DIR=$(MCP_METHOD_KIND_DIRECT_BUILD_DIR) SANITIZE= CBM_USE_RUST_MCP_METHOD_KIND_ONLY=1 cbm | rg -F 'src/mcp/mcp.c'

